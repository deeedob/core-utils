[user]
	email = dennis.ob@protonmail.com
	name = deeedob
	username = deeedob
[includeIf "gitdir:**/Qt/"]
	path = ~/Qt/.gitconfig
[core]
	defaultBranch = main
	autocrlf = input
	pager = delta
	editor = nvim
	whitespace = trailing-space,-space-before-tab,cr-at-eol
[interactive]
	diffFilter = delta --color-only
[diff]
	mnemonicPrefix = true
[difftool]
	prompt = false
[difftool "nvr"]
	cmd = nvr -s -d $LOCAL $REMOTE
[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"
[merge]
	tool = nvimdiff
[mergetool]
	prompt = false
[mergetool "nvr"]
	cmd = nvr -s -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd J | wincmd ='
[mergetool "meld"]
	cmd = meld "$LOCAL" "$MERGED" "$REMOTE" --output "$MERGED"
[commit]
	template = ~/.config/git/git-commit-template
[alias]
	ci  = commit
	st  = status
	di  = diff
	co  = checkout
	ann = blame
	sub = submodule update --remote --merge
[credential]
	helper = cache --timeout=36000
[rerere]
	enabled = true
	autoupdate = true
[rebase]
	stat = true
	autoSquash = true
[color]
	ui = auto
[web]
	browser = firefox
[grep]
	lineNumber = true
[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
	syntax-theme = Nord
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[branch]
	sort = -committerdate
[column]
	ui = auto
[tag]
	sort = version:refname
[log]
	date = iso
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
